{
    "_comment": "DPA-2 + DP-LONG training configuration for BF3/CF4 isotope effect force field. All hyperparameters preserved as-is (production tuning values).",

    "model": {
        "type_map": ["B", "F"],
        "descriptor": {
            "type": "dpa2",
            "repinit": {
                "tebd_dim": 8,
                "rcut": 6.0,
                "rcut_smth": 0.5,
                "nsel": 120
            },
            "repformer": {
                "rcut": 6.0,
                "rcut_smth": 0.5,
                "nsel": 120,
                "nlayers": 6,
                "g1_dim": 128,
                "g2_dim": 64,
                "attn2_dim": 32,
                "axis_neuron": 8,
                "update_g1_has_conv": true,
                "update_g2_has_conv": true,
                "update_g1_has_attn": true,
                "update_g2_has_attn": true,
                "update_g1_has_mp": false,
                "update_g2_has_mp": false,
                "update_style": "res_residual",
                "update_residual": 0.01,
                "update_residual_init": "norm",
                "attn2_has_gate": true,
                "use_sqrt_nnei": true
            },
            "add_tebd_to_repformer_out": true
        },
        "fitting_net": {
            "type": "ener",
            "neuron": [240, 240, 240],
            "resnet_dt": true,
            "numb_fparam": 0,
            "numb_aparam": 0,
            "seed": 42
        },
        "type_embedding": {
            "neuron": [32, 32],
            "resnet_dt": false,
            "seed": 42
        }
    },

    "learning_rate": {
        "type": "exp",
        "decay_steps": 5000,
        "start_lr": 0.001,
        "stop_lr": 5e-8,
        "scale_by_worker": "linear"
    },

    "loss": {
        "type": "ener",
        "start_pref_e": 0.02,
        "limit_pref_e": 2.0,
        "start_pref_f": 1000,
        "limit_pref_f": 1.0,
        "start_pref_v": 0.0,
        "limit_pref_v": 0.0,
        "atom_pref": {
            "B": 0.8,
            "F": 1.0
        },
        "enable_atom_pref": true
    },

    "training": {
        "training_data": {
            "systems": ["../data/train/bf3_dimer/"],
            "batch_size": 4,
            "sys_probs": null,
            "auto_prob_style": "prob_sys_size"
        },
        "validation_data": {
            "systems": ["../data/test/bf3_dimer/"],
            "batch_size": 2
        },
        "numb_steps": 1000000,
        "seed": 42,
        "disp_file": "lcurve.out",
        "disp_freq": 1000,
        "save_freq": 10000,
        "save_ckpt": "model.ckpt",
        "disp_training": true,
        "time_training": true,
        "profiling": false,
        "profiling_file": "timeline.json",
        "enable_profiler": false,
        "tensorboard": true,
        "tensorboard_log_dir": "log",
        "tensorboard_freq": 1000
    },

    "dp_long": {
        "enable": true,
        "q_atom": [0.0, 0.0],
        "ewald_h": 1.0,
        "ewald_beta": 0.4,
        "rcut_lr": 12.0,
        "model_charge_map": null
    }
}
